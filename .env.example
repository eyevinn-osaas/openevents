# =============================================================================
# OpenEvents Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=OpenEvents

# Default currency for the platform (ISO 4217 code)
DEFAULT_CURRENCY=SEK

# =============================================================================
# Database (PostgreSQL on OSC)
# =============================================================================
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/openevents

# =============================================================================
# Authentication (NextAuth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Object Storage (MinIO on OSC)
# =============================================================================
# MinIO/S3 endpoint URL
S3_ENDPOINT=https://your-minio-endpoint.example.com
S3_PUBLIC_URL=https://your-minio-endpoint.example.com

# S3 credentials (same as MinIO root user/password)
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# S3 bucket name for media files
# NOTE: You must create this bucket manually. See docs/SETUP_STORAGE.md
S3_BUCKET_NAME=openevents-media

# S3 region (can be any value for MinIO)
S3_REGION=us-east-1

# =============================================================================
# Cache (Valkey/Redis on OSC)
# =============================================================================
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://:password@localhost:6379

# =============================================================================
# Email Configuration
# =============================================================================
# OSC does not provide a built-in SMTP service.
#
# EMAIL_MODE options:
#   - "development": Emails logged to console (no SMTP needed)
#   - "smtp": Use external SMTP provider (default in production)
#
# For development, just set EMAIL_MODE=development
# For production, configure an external SMTP provider below

EMAIL_MODE=development

# SMTP Configuration (only needed when EMAIL_MODE=smtp)
# Recommended providers:
#   - SendGrid: smtp.sendgrid.net (port 587)
#   - Postmark: smtp.postmarkapp.com (port 587)
#   - Mailgun: smtp.mailgun.org (port 587)
#   - Amazon SES: email-smtp.<region>.amazonaws.com (port 587)

# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# From email address (used in all outgoing emails)
EMAIL_FROM=noreply@openevents.local

# =============================================================================
# Payments (PayPal - Stub for now)
# =============================================================================
# Set to 'true' to use PayPal sandbox, 'false' for production
PAYPAL_SANDBOX=true

# PayPal API credentials
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# PayPal Webhook ID (REQUIRED for production)
# Create a webhook in PayPal Developer Dashboard pointing to:
# https://your-domain.com/api/webhooks/paypal
PAYPAL_WEBHOOK_ID=your-webhook-id

# Skip webhook signature verification (LOCAL DEVELOPMENT ONLY!)
# WARNING: Never set this in production or staging environments.
# Both SKIP_WEBHOOK_VERIFICATION=true AND NODE_ENV=development are required.
# SKIP_WEBHOOK_VERIFICATION=true

# =============================================================================
# OSC (Eyevinn Open Source Cloud)
# =============================================================================
# Access token for OSC API (for deployment automation)
# OSC_ACCESS_TOKEN=your-osc-access-token

# =============================================================================
# Development
# =============================================================================
# Enable verbose logging in development
# DEBUG=prisma:query

# =============================================================================
# Production Checklist
# =============================================================================
# Before deploying to production:
# 1. Set NODE_ENV=production
# 2. Update NEXT_PUBLIC_APP_URL to your production URL
# 3. Generate a strong NEXTAUTH_SECRET
# 4. Configure OAuth providers with production credentials
# 5. Set EMAIL_MODE=smtp and configure SMTP provider
# 6. Set up PayPal production credentials
# 7. Create the S3 bucket (see docs/SETUP_STORAGE.md)
